        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(onyx_db_pool_checkout_total{engine=\"sync\"})",
          "legendFormat": "Total Checkouts",
          "refId": "A"
        }
      ]
    }
