# ============================================================
# CSP Platform 環境變數配置
# 複製此檔為 .env 後修改：cp .env.example .env
# ============================================================

# ---------- 基本設定 ----------
SECRET_KEY=your-secret-key-change-this-in-production

# ---------- 資料庫（PostgreSQL）----------
DATABASE_URL=postgresql://csp:csp_password@postgres:5432/csp
DB_USER=csp
DB_PASSWORD=csp_password
DB_NAME=csp

# ---------- JWT 設定 ----------
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- 管理員帳號（首次啟動自動建立）----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ---------- Proxy 設定 ----------
EMBEDDING_TIMEOUT=30
LLM_TIMEOUT=120
PROXY_MAX_RETRIES=3

# ---------- 背景任務 ----------
HEALTH_CHECK_INTERVAL=60
USAGE_BATCH_SIZE=100
USAGE_FLUSH_INTERVAL=5

# ---------- Nginx 設定 ----------
# Nginx 對外 port（預設 80）
NGINX_PORT=80
# 使用者瀏覽器存取的基底 URL，用於平台卡片連結
SITE_URL=http://localhost

# ============================================================
# 自動註冊模型（啟動時寫入 DB）
#
# 方式一：JSON 陣列（適合一次配置多個模型）
# ============================================================
AUTO_REGISTER_MODELS=[{"name":"llama3-70b","display_name":"Llama 3 70B Instruct","model_type":"llm","endpoint_url":"http://vllm-llm:8000","api_version":"v1","description":"vLLM 部署的 Llama 3 70B 模型","context_window":8192},{"name":"nv-embed-v2","display_name":"NVIDIA NV-Embed V2","model_type":"embedding","endpoint_url":"http://triton-embedding:8000","api_version":"v2","description":"Triton 部署的 NV-Embed-V2 嵌入模型"},{"name":"aia/asrd","display_name":"AIA ASRD Agent","model_type":"agent","endpoint_url":"http://mlsteam-host:45023","api_version":"v1","description":"MLSteam 部署的 ASRD Agent","base_model":"llama3-70b"}]

# ============================================================
# 方式二：每個模型用獨立環境變數（適合逐一配置）
# 格式：MODEL_<NAME>_<FIELD>
# NAME: 底線分隔，會自動轉為小寫連字號（如 LLAMA3_70B -> llama3-70b）
# FIELD: HOST, PORT, TYPE, DISPLAY_NAME, API_VERSION, DESCRIPTION,
#        CONTEXT_WINDOW, BASE_MODEL
#
# 兩種方式可並存，JSON 中已有的 name 會優先，env var 不會覆蓋
# ============================================================
# MODEL_LLAMA3_70B_HOST=vllm-llm
# MODEL_LLAMA3_70B_PORT=8000
# MODEL_LLAMA3_70B_TYPE=llm
# MODEL_LLAMA3_70B_DISPLAY_NAME=Llama 3 70B Instruct
# MODEL_LLAMA3_70B_CONTEXT_WINDOW=8192
#
# MODEL_NV_EMBED_V2_HOST=triton-embedding
# MODEL_NV_EMBED_V2_PORT=8000
# MODEL_NV_EMBED_V2_TYPE=embedding
# MODEL_NV_EMBED_V2_API_VERSION=v2
#
# MODEL_AIA_ASRD_HOST=mlsteam-host
# MODEL_AIA_ASRD_PORT=45023
# MODEL_AIA_ASRD_TYPE=agent
# MODEL_AIA_ASRD_BASE_MODEL=llama3-70b

# ============================================================
# 自動註冊平台連結（儀表板卡片）
# 格式：JSON 陣列，每筆包含 name, url, icon, description
#
# url 說明：
#   - 直連平台：http://n8n:5678
#   - 透過 nginx 代理：${SITE_URL}/n8n
#   - 外部網址：https://mlsteam.ncsist.org.tw
# ============================================================
AUTO_REGISTER_LINKS=[{"name":"n8n 工作流程","url":"http://n8n:5678","icon":"workflow","description":"自動化工作流程平台"},{"name":"GitLab","url":"http://gitlab:8929","icon":"git","description":"程式碼版本控制"},{"name":"ANILA LM","url":"http://anilalm:3000","icon":"notebook","description":"AI 筆記本"},{"name":"MLSteam","url":"https://mlsteam.ncsist.org.tw","icon":"cpu","description":"MLOps 平台 - Agent 開發與部署"}]
