# Copy to `.env.local` and fill in for local dev. Vite reads VITE_* vars at
# build/dev time and inlines them into the client bundle.

# CSP control-plane base URL (JWT /api/* + data-plane /v1/*).
# Default dev port is 8000.
VITE_CSP_BASE_URL=http://localhost:8000

# ANILA Router base URL (data-plane /v1/* with router pseudo-agent dispatch).
# Default dev port is 9000.
VITE_ROUTER_BASE_URL=http://localhost:9000
