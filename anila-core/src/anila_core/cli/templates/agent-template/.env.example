# Copy to .env and fill in values before running.

# CSP Platform base URL (where myCSPPlatform is running)
CSP_BASE_URL=http://localhost:8000

# CSP API Key issued to this agent (get from CSP admin)
CSP_API_KEY=sk-your-agent-api-key

# Service-to-service token — must match CSP_SERVICE_TOKEN on the CSP side
CSP_SERVICE_TOKEN=dev-service-token

# Model name to use for LLM calls (must be registered in CSP model_registry)
MODEL=gpt-4o-mini

# Embedding model (if your agent does vector search)
EMBEDDING_MODEL=text-embedding-3-small

# Development mode: set to true to skip auth checks locally
API_DEV_MODE=false
