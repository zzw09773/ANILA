# AgenticRAG — 環境變數設定範例
# 複製此檔案為 .env 並填入實際值：
#   cp .env.example .env

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_URL=https://172.16.120.35/v1
LLM_API_KEY=not-set
MODEL=google/gemma4

# ── Embedding Provider (NV-Embed-V2) ──────────────────────────────────────────
EMBEDDING_URL=https://172.16.120.35/v1
EMBEDDING_API_KEY=not-set
EMBEDDING_MODEL=nvidia/NV-embed-V2
EMBEDDING_DIMENSION=4096
EMBEDDING_VERIFY_SSL=false

# ── Vision / VLM（處理 PDF、DOCX 內嵌圖片 + 獨立圖片檔）────────────────────────
# 支援任何 OpenAI-compatible 的 VLM endpoint（maverick4 / gemma4-vision / ...）
VISION_URL=https://172.16.120.35/v1
VISION_API_KEY=not-set
VISION_MODEL=meta/llama-4-maverick
VISION_VERIFY_SSL=false
VISION_MAX_IMAGE_BYTES=8388608
VISION_ENABLED=true

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://agentic:agentic@localhost:5432/agentic_rag
PG_POOL_MIN=2
PG_POOL_MAX=10
PG_SSL=disable

# ── Chunking（階層式切分，chunk_size 只是遇到超大段落時的 fallback 上限）─────
CHUNK_SIZE=1024
CHUNK_OVERLAP=64

# ── RAG Retrieval ─────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_SCORE=0.7
RAG_INCLUDE_PARENT_CONTEXT=true

# ── Traditional Chinese FTS Tokenizer ────────────────────────────────────────
# bigram (default): 純 Python，零依賴，CJK 字元 bigram + ASCII 詞
# ckip:    Academia Sinica CKIP 斷詞器（需 pip install 'agentic-rag[zh]'）
RAG_TOKENIZER=bigram

# ── Cross-Encoder Reranker（hybrid search 後對 top-(k×N) 重排）────────────────
# 啟用後會把 RRF 結果再餵 cross-encoder，回傳 RAG_TOP_K 筆最相關的內容。
# 後端：vLLM 以 --task score 啟動，跑 mixedbread-ai/mxbai-rerank-large-v1
#       （Apache-2，mixedbread.ai，德國），透過 OpenAI-compatible /v1/score
#       端點呼叫。預期部署在你們現有 Triton/vLLM 模型伺服器上。
RAG_RERANKER_ENABLED=false
RAG_RERANKER_URL=http://172.16.120.35:8001/v1
RAG_RERANKER_MODEL=mxbai-rerank-large-v1
RAG_RERANKER_API_KEY=not-set
RAG_RERANKER_VERIFY_SSL=false
RAG_RERANK_POOL_MULTIPLIER=3

# ── PDF OCR Fallback（掃描檔 / 字型子集化的 PDF）─────────────────────────────
# pymupdf4llm 抽不到文字或留下大量 <?> 時，自動把每頁 raster 後送到既有
# VISION_URL（meta/llama-4-maverick）做 prompt-based OCR。重用 vision
# 連線設定，不需另外部署 EasyOCR/Tesseract。
PDF_OCR_FALLBACK=false
PDF_OCR_DPI=200
PDF_OCR_CONCURRENCY=4
PDF_OCR_MAX_PAGES=100
# PDF_OCR_VISION_PROMPT=請逐字輸出此圖片中的繁體中文，保留段落結構，不要翻譯也不要摘要。

# ── Document Parser Backend（PDF / DOCX / PPTX / XLSX / HTML）─────────────────
# native (預設):  pymupdf4llm + python-docx + odfpy。輕量、零模型下載。
# docling:        IBM Docling（Apache-2，美國），layout-aware + 表格結構
#                  還原 + 內建 EasyOCR。第一次執行會下載 ~1 GB 模型，
#                  CPU 推論明顯較慢。需 pip install 'agentic-rag[docling]'。
DOC_PARSER=native
DOCLING_OCR_LANGS=ch_tra,en
# DOCLING_TABLE_STRUCTURE=true
# 開啟後會額外下載 ~3 GB 的 IBM Granite-Vision-3.2-2B 圖片描述模型。
# DOCLING_PICTURE_DESCRIPTION=false

# ── API / Auth ────────────────────────────────────────────────────────────────
# API_KEY=your-secret-key    # 留空則不啟用 Bearer token 驗證
API_DEV_MODE=false
UPLOAD_DIR=/tmp/agentic_rag_uploads

# ── ANILA / CSP Platform Integration（選用）───────────────────────────────────
# 當本 agent 被註冊到 myCSPPlatform 時，平台會在每個請求注入
#   X-CSP-Service-Token: <CSP_SERVICE_TOKEN>
# middleware 會驗證這個 header；設為空值則跳過檢查（本機開發）。
#
# CSP_BASE_URL / CSP_API_KEY 啟用後，LLM 與 embedding 呼叫會改走 CSP proxy
# 而不是直連內網 vLLM；適合 CSP 有統一 audit / quota 控制的場景。
# 兩邊都留空則本 agent 以獨立模式運行（直連 LLM_URL / EMBEDDING_URL）。
CSP_SERVICE_TOKEN=
CSP_BASE_URL=
CSP_API_KEY=
