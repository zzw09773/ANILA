# ANILA Core — 環境變數設定範例
# 複製此檔案為 .env 並填入實際值：
#   cp .env.example .env

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_URL=https://172.16.120.35/v1
LLM_API_KEY=not-set
MODEL=google/gemma4

# ── Embedding Provider ────────────────────────────────────────────────────────
EMBEDDING_URL=https://172.16.120.35/v1
EMBEDDING_API_KEY=not-set
EMBEDDING_MODEL=nvidia/nv-embed-V2
EMBEDDING_DIMENSION=4096
EMBEDDING_VERIFY_SSL=false

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://anila:anila@localhost:5432/anila_rag
PG_POOL_MIN=2
PG_POOL_MAX=10
PG_SSL=disable

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# ── RAG Retrieval ─────────────────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MIN_SCORE=0.7

# ── API / Auth ────────────────────────────────────────────────────────────────
# API_KEY=your-secret-key    # 留空則不啟用 Bearer token 驗證
API_DEV_MODE=false
UPLOAD_DIR=/tmp/anila_uploads
