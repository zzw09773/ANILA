# ─────────────────────────────────────────────────────────────────────────────
# AgenticRAG (RAG Sample Agent) — environment variables
#
# Copy to `.env` and fill in real values:
#     cp .env.example .env
#
# Only the variables actually read by api.py / index_documents.py are listed.
# Ordered by likelihood of being customized.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM (chat completions backend) ───────────────────────────────────────────
# If deployed behind myCSPPlatform, set CSP_BASE_URL + CSP_API_KEY and the
# direct URLs below are ignored (routed through CSP's OpenAI-compat proxy).
# For local dev or standalone deployment, set LLM_URL + LLM_API_KEY directly.
CSP_BASE_URL=
CSP_API_KEY=
LLM_URL=https://172.16.120.35/v1
LLM_API_KEY=not-set
MODEL=google/gemma4

# ── Embedding (for semantic search) ──────────────────────────────────────────
# Same "through CSP or direct" rule. NV-Embed-V2 is the default (dim=4096).
EMBEDDING_URL=https://172.16.120.35/v1
EMBEDDING_API_KEY=not-set
EMBEDDING_MODEL=nvidia/nv-embed-v2
EMBEDDING_VERIFY_SSL=false

# ── PostgreSQL (pgvector store) ──────────────────────────────────────────────
# docker-compose overrides this to point at the `db` service inside the network.
DATABASE_URL=postgresql://anila:anila@localhost:5432/anila_rag

# ── RAG retrieval ────────────────────────────────────────────────────────────
RAG_TOP_K=5                # chunks to pull per search (per modality)
RAG_MIN_SCORE=0.5          # cosine-similarity floor for vector hits
RAG_MIN_SCORE_RETRY=0.3    # fallback floor if primary threshold returns nothing

# ── CSP service-to-service auth ──────────────────────────────────────────────
# Set this to the token myCSPPlatform provisions for this agent. Leave empty
# for local dev (auth middleware runs in dev_mode=True and skips token check).
CSP_SERVICE_TOKEN=

# ── Optional: custom RAG system prompt ───────────────────────────────────────
# Overrides the built-in zh-TW default. The client's own `role=system` message
# still takes precedence over this env var.
# RAG_SYSTEM_PROMPT=
