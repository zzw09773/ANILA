# Backend that the dev proxy points at. Override per-environment.
VITE_CSP_BACKEND=http://localhost:8000

# Default chat model name (must exist in CSP model_registry OR be an approved Agent name).
VITE_DEFAULT_CHAT_MODEL=gpt-4o-mini

# Base path under which the SPA is served. Default '/' for local dev.
# When the docker-compose stack runs ANILALM behind the ANILA reverse
# proxy at /anilalm/ this is set via the Dockerfile build arg.
# BASE_PATH=/anilalm/
