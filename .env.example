# ANILA Platform — root .env 範本 (prod 預設,branch SSO)
# ============================================================================
# 複製成 .env 並填入正式值:
#   cp .env.example .env
#
# 模式:**內網 production**。所有 ANILA_ALLOW_* opt-in flag 預設關閉,任何
# dev 預設值都會被 startup_security RuntimeError 擋下;缺 secret 直接 fail-fast。
#
# 切回 dev 模式只需要:
#   ANILA_ALLOW_DEV_SECRET=1
#   ANILA_ALLOW_HTTP_ENDPOINT=1
#   ANILA_ALLOW_PRIVATE_ENDPOINT=1
#   REQUIRE_CARD_LOGIN_ONLY=false
# 即可重開本機帳密 + LAN endpoint 註冊。
# ============================================================================

# ── 啟動安全檢查 ──────────────────────────────────────────────────────────
# 0 (prod) = startup_security 對 dev 預設值 (SECRET_KEY / ADMIN_PASSWORD /
#  CSP_SERVICE_TOKEN / DB_PASSWORD / INTERNAL_PLATFORM_API_KEY / CODESERVER_PASSWORD)
#  直接 RuntimeError 拒絕啟動。
# 1 (dev)  = 僅 warn,允許 dev 預設值繼續跑。
ANILA_ALLOW_DEV_SECRET=0

# ── url_guard SSRF opt-in (dev only) ──────────────────────────────────────
# 0 = 拒絕 http:// + RFC1918 私網 IP 註冊 endpoint。
# 1 = 允許 (dev / LAN agent 才開)。
# loopback / link-local / cloud metadata / docker service name 永遠擋。
ANILA_ALLOW_HTTP_ENDPOINT=0
ANILA_ALLOW_PRIVATE_ENDPOINT=0

# ── CSP 核心 secret ───────────────────────────────────────────────────────
# 全部 [REQUIRED in prod] — docker-compose 用 ${VAR:?must be set},缺值直接 fail。
# 生成: openssl rand -hex 32 (產 64 hex chars)
CSP_SECRET_KEY=<openssl rand -hex 32>
CSP_SERVICE_TOKEN=<openssl rand -hex 32>

# ── 內部 service-to-service token (auto_seed 寫入 ingestion-worker user) ──
# 生成: printf "sk-internal-" && openssl rand -hex 24
INTERNAL_PLATFORM_API_KEY=<sk-internal-<openssl rand -hex 24>>

# ── code-server (cold-stored,prod 啟用但 nginx route 預設 deny) ───────────
# 解凍時:改 nginx.conf 拿掉 /codeserver 的 return 404,然後 exec 進容器改密碼。
# 生成: openssl rand -base64 24
CODESERVER_PASSWORD=<openssl rand -base64 24>
CODESERVER_WORKSPACE=./share/codeserver-sandbox

# ── 內網 hostname / IP ────────────────────────────────────────────────────
# 影響 n8n N8N_HOST + WEBHOOK_URL、gitlab external_url。Cold-storage 服務
# 解凍時就不用再改 compose。
ANILA_HOST=<your-intranet-fqdn-or-ip>
# N8N_WEBHOOK_URL=https://<your-intranet-fqdn>/n8n/

# ── branch SSO: 中科院憑證卡登入 ──────────────────────────────────────────
# 內網 prod 唯一登入方式。使用者 PC 上的中華電信 HiPKI 元件 (localhost:16888,
# PKCS#11 API + HTTP wrapper) 處理 PIN + 卡片硬體簽章,輸出 PKCS#7 格式給
# backend 抽 employee_id (見 myCSPPlatform/backend/app/services/card_auth.py)。
ENABLE_CARD_LOGIN=true
REQUIRE_CARD_LOGIN_ONLY=true

# CARD_INITIAL_OWNERS: CSV 員工編號清單。列在裡面的人第一次刷卡建為
# role="owner" + is_approved=True (bootstrap)。其他人走 pending →
# 完成註冊 (填 department) → admin 核准。**至少要列一個自己的員工編號**
# 否則 docker-compose ${CARD_INITIAL_OWNERS:?...} 會 fail-fast。
CARD_INITIAL_OWNERS=<your-employee-id,or-csv-list>

# ── n8n (cold-stored) ─────────────────────────────────────────────────────
# Code Node 模組白名單寫死,避免變成任意 require() 的 RCE 平台。
# TLS 驗證預設開,要連自簽 endpoint 請逐節點設 self-signed CA。
N8N_TLS_REJECT_UNAUTHORIZED=1
N8N_NODE_FUNCTION_ALLOW_EXTERNAL=axios,lodash,dayjs,xlsx
# N8N_NODE_FUNCTION_ALLOW_BUILTIN=crypto,url
# N8N_WEBHOOK_URL=https://anila.internal/n8n/

# ── 模型 endpoint 覆寫 (compose 預設指向 anila-models stack) ──────────────
# endpoint_url 必須是 base URL,不要加 /v1 結尾,proxy 自己拼。
# LOCAL_LLM_BASE_URL=http://gpt-oss-20b:8000
# LOCAL_LLM_MODEL=gpt-oss-20b
# LOCAL_EMBEDDING_BASE_URL=http://nv-embed-proxy:8000
# LOCAL_EMBEDDING_MODEL=nvidia/NV-embed-V2
