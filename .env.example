# ANILA Platform — root .env 範本（給 docker-compose 取用）
# 複製為 .env 並填入正式值：
#   cp .env.example .env
#
# Production：請務必移除 ANILA_ALLOW_DEV_SECRET 以啟用 startup_security
# 對 dev 預設值的拒絕。所有以下標記 [REQUIRED] 的欄位必設。

# ── 啟動安全檢查 ──
# 設為 1 時，startup_security 對下列 dev 預設值（SECRET_KEY / ADMIN_PASSWORD /
# CSP_SERVICE_TOKEN / DB_PASSWORD / CODESERVER_PASSWORD / INTERNAL_PLATFORM_API_KEY）
# 只 warn 不 raise；正式環境必拿掉或設為 0。
ANILA_ALLOW_DEV_SECRET=1

# Sprint 5 X / H4 + Sprint 7 X follow-up：url_guard 兩個 dev opt-in。
# 兩個都針對「ANILA 是 on-prem 平台、agent 常在 LAN 內網」這個 first-class
# case 鋪路。loopback / link-local / cloud metadata / docker service name
# 一律永遠擋，不受任一 flag 影響。
# ANILA_ALLOW_HTTP_ENDPOINT=1     # 鬆綁 http scheme（cleartext 風險）
# ANILA_ALLOW_PRIVATE_ENDPOINT=1  # 鬆綁 RFC 1918 私網 IP（10.x / 172.16-31.x / 192.168.x）

# ── CSP backend ──
# [REQUIRED in prod] 拿真亂數（例如 openssl rand -hex 32）
CSP_SECRET_KEY=dev-secret-key-change-in-prod
CSP_SERVICE_TOKEN=dev-service-token

# ── 內部 service-to-service token（auto_seed 寫進 ingestion-worker user）──
# [REQUIRED in prod]
INTERNAL_PLATFORM_API_KEY=sk-internal-worker-changeme

# ── code-server（C3 強制必設）──
# 不要直接指 ./（會把 .env / 私鑰 / credentials 暴露）。SSO 接上後可移除整個 service。
# [REQUIRED]
CODESERVER_PASSWORD=please-rotate-this-codeserver-password
# [REQUIRED] 例如 ./share/codeserver-sandbox 或其他不含機密的工作目錄
CODESERVER_WORKSPACE=./share/codeserver-sandbox

# ── n8n（C2 收斂）──
# 預設啟用 TLS 驗證；要連自簽 endpoint 請逐節點設 self-signed CA，不要全域關。
# N8N_TLS_REJECT_UNAUTHORIZED=1
# Code Node 模組白名單，預設 axios,lodash,dayjs / crypto,url
# N8N_NODE_FUNCTION_ALLOW_EXTERNAL=axios,lodash,dayjs
# N8N_NODE_FUNCTION_ALLOW_BUILTIN=crypto,url
# N8N_WEBHOOK_URL=https://172.16.120.35/n8n/

# ── ANILA Functions v1 ──
# CSP ↔ worker-api 共用 secret. 隨機生成 (e.g. `openssl rand -hex 32`).
# ANILA_FUNCTIONS_API_SECRET=replace-with-random-32-byte-hex

# AES-256-GCM key for admin valves at-rest encryption.
# Must be base64-encoded 32 bytes. Generate via:
#   python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
# ANILA_FUNCTIONS_VALVES_KEY=

# Egress proxy allowlist for sandbox-exec (sandbox-extract has no
# egress at all — extract-net is internal:true with no proxy bridge).
# Format: comma-separated `host:port` entries.
# Example: csp:8000,router:9000,internal-lint.intra:443
# ANILA_FUNCTIONS_EGRESS_ALLOWLIST=

# Where CSP reaches worker-api (internal hostname on anila-net).
# Default works inside docker-compose; override only for non-compose deploys.
# ANILA_FUNCTIONS_WORKER_API_URL=http://anila-functions-worker-api:8000

# ── 模型 endpoint（compose 預設已對齊 on-prem 實際服務；以下為覆寫範例）──
# 預設：gpt-oss-20b @ 172.16.120.35:7000、NV-embed-V2 @ host.docker.internal:7011/v1。
# 如果你要用 Ollama 或其他 OpenAI-compatible LLM，把對應行解開並改成你的 endpoint：
# LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
# LOCAL_LLM_MODEL=qwen2.5:14b
# LOCAL_EMBEDDING_BASE_URL=http://host.docker.internal:7011/v1
# LOCAL_EMBEDDING_MODEL=nvidia/NV-embed-V2
