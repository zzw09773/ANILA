# ANILA Platform — root .env 範本（給 docker-compose 取用）
# 複製為 .env 並填入正式值：
#   cp .env.example .env
#
# Production：請務必移除 ANILA_ALLOW_DEV_SECRET 以啟用 startup_security
# 對 dev 預設值的拒絕。所有以下標記 [REQUIRED] 的欄位必設。

# ── 啟動安全檢查 ──
# 設為 1 時，startup_security 對下列 dev 預設值（SECRET_KEY / ADMIN_PASSWORD /
# CSP_SERVICE_TOKEN / DB_PASSWORD / CODESERVER_PASSWORD / INTERNAL_PLATFORM_API_KEY）
# 只 warn 不 raise；正式環境必拿掉或設為 0。
ANILA_ALLOW_DEV_SECRET=1

# ── CSP backend ──
# [REQUIRED in prod] 拿真亂數（例如 openssl rand -hex 32）
CSP_SECRET_KEY=dev-secret-key-change-in-prod
CSP_SERVICE_TOKEN=dev-service-token

# ── 內部 service-to-service token（auto_seed 寫進 ingestion-worker user）──
# [REQUIRED in prod]
INTERNAL_PLATFORM_API_KEY=sk-internal-worker-changeme

# ── code-server（C3 強制必設）──
# 不要直接指 ./（會把 .env / 私鑰 / credentials 暴露）。SSO 接上後可移除整個 service。
# [REQUIRED]
CODESERVER_PASSWORD=please-rotate-this-codeserver-password
# [REQUIRED] 例如 ./share/codeserver-sandbox 或其他不含機密的工作目錄
CODESERVER_WORKSPACE=./share/codeserver-sandbox

# ── n8n（C2 收斂）──
# 預設啟用 TLS 驗證；要連自簽 endpoint 請逐節點設 self-signed CA，不要全域關。
# N8N_TLS_REJECT_UNAUTHORIZED=1
# Code Node 模組白名單，預設 axios,lodash,dayjs / crypto,url
# N8N_NODE_FUNCTION_ALLOW_EXTERNAL=axios,lodash,dayjs
# N8N_NODE_FUNCTION_ALLOW_BUILTIN=crypto,url
# N8N_WEBHOOK_URL=https://172.16.120.35/n8n/

# ── 模型 endpoint（保持原 dev 預設）──
# LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
# LOCAL_LLM_MODEL=gpt-4o-mini
# LOCAL_EMBEDDING_BASE_URL=http://host.docker.internal:7011/v1
# LOCAL_EMBEDDING_MODEL=nvidia/NV-embed-V2
