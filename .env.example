# Copy to .env and fill in.

# OpenAI-compatible endpoint. Point this at vLLM, Ollama, OpenAI, Together, etc.
ANILA_BASE_URL=http://localhost:8000/v1
ANILA_API_KEY=sk-local
ANILA_MODEL=gpt-4o-mini

# Where short-term sessions and long-term memory live.
# Defaults to ./.anila/ in the working directory.
ANILA_HOME=

# Set to "1" to enable end-of-turn auto memory extraction.
# Off by default — costs one extra LLM call per turn.
ANILA_AUTO_MEMORY=0

# Logging verbosity: DEBUG / INFO / WARNING / ERROR.
ANILA_LOG_LEVEL=INFO

# --- pgvector retriever (optional, install the [pgvector] extra first) ---
# Pick ONE of the two flavours below. Leave both unset to stay on DummyRetriever.

# Flavour A: generic langchain_postgres schema (langchain_pg_collection +
# langchain_pg_embedding tables). Use when your data was ingested via langchain.
# PGVECTOR_URL=postgresql+psycopg2://<user>:<password>@<host>:<port>/<db>
# PGVECTOR_COLLECTION=<collection name>

# Flavour B: ANILA platform native schema (ingestion_collections +
# document_chunks with halfvec + RLS). Takes precedence over Flavour A.
# PGVECTOR_URL=postgresql://<user>:<password>@<host>:<port>/<db>
# ANILA_COLLECTION_ID=<int collection id>
# ANILA_SSL_VERIFY=0   # 1 by default; 0 for self-signed certs on the embed endpoint

# Embedding model + endpoint. Both default to ANILA_BASE_URL / ANILA_API_KEY
# when the dedicated vars are unset. Override only if your embed endpoint
# differs from your chat endpoint.
# ANILA_EMBED_MODEL=text-embedding-3-small
# ANILA_EMBED_BASE_URL=
# ANILA_EMBED_API_KEY=
