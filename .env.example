# ANILA Platform — root .env 範本（給 docker-compose 取用）
# 複製為 .env 並填入正式值：
#   cp .env.example .env
# Production 部署需另外提供包含真實 secret 的 .env，並務必把
# ANILA_ALLOW_DEV_SECRET 取消（拿掉這個 var 或設為 0）。

# ── 啟動安全檢查 ──
# 1 = startup_security 對 dev 預設值（SECRET_KEY / ADMIN_PASSWORD /
# CSP_SERVICE_TOKEN / DB_PASSWORD / INTERNAL_PLATFORM_API_KEY）只 warn。
# 正式環境必拿掉。
ANILA_ALLOW_DEV_SECRET=1

# ── url_guard SSRF opt-in（dev only）──
# 兩個都打開 = 容許 http://172.16.x.x:port 之類的 LAN agent；正式環境拿掉。
# loopback / link-local / cloud metadata / docker service name 永遠擋。
ANILA_ALLOW_HTTP_ENDPOINT=1
ANILA_ALLOW_PRIVATE_ENDPOINT=1

# ── CSP ──
# [REQUIRED in prod]  openssl rand -hex 32
CSP_SECRET_KEY=dev-secret-key-change-in-prod
CSP_SERVICE_TOKEN=dev-service-token

# ── 內部 service-to-service token（auto_seed 寫入 ingestion-worker user）──
# [REQUIRED in prod]
INTERNAL_PLATFORM_API_KEY=sk-internal-worker-changeme

# ── code-server ──
# 工作目錄不要直接指 ./（會把整個 repo 含 .env / 私鑰 / credentials 一起暴露）。
# 指 sandbox 子目錄；不存在會自動建立。SSO 接上後可拿掉整個 service。
CODESERVER_PASSWORD=dev-only-codeserver-password-please-rotate
CODESERVER_WORKSPACE=./share/codeserver-sandbox

# ── n8n ──
# 預設啟用 TLS 驗證；要連自簽 endpoint 請逐節點設 self-signed CA，不要全域關。
# N8N_TLS_REJECT_UNAUTHORIZED=1
# Code Node 模組白名單
# N8N_NODE_FUNCTION_ALLOW_EXTERNAL=axios,lodash,dayjs
# N8N_NODE_FUNCTION_ALLOW_BUILTIN=crypto,url
# webhook URL（無設會 fallback 到 ANILA_HOST）
# N8N_WEBHOOK_URL=https://172.16.120.35/n8n/

# ── 模型 endpoint 覆寫（compose 預設指向 anila-models stack）──
# endpoint_url 必須是 base URL，不要加 /v1 結尾，proxy 自己拼。
# LOCAL_LLM_BASE_URL=http://gpt-oss-20b:8000
# LOCAL_LLM_MODEL=gpt-oss-20b
# LOCAL_EMBEDDING_BASE_URL=http://nv-embed-proxy:8000
# LOCAL_EMBEDDING_MODEL=nvidia/NV-embed-V2
