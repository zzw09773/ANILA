# ── ANILA 主 repo 的 .gitignore ──────────────────────────────────────────────
# 子專案 (myCSPPlatform / AgenticRAG / anila-core / ANILA_UI / onyx) 各自的
# .gitignore 仍生效；此檔處理跨專案共通的忽略規則。

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg
*.egg-info/
.eggs/
build/
develop-eggs/
.installed.cfg
pip-log.txt
pip-delete-this-directory.txt

# Test / lint / type-check caches
.pytest_cache/
.ruff_cache/
.mypy_cache/
.pyre/
.pytype/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# Virtualenvs
.venv/
venv/
env/
ENV/

# Local SQLite 測試檔
.pytest-csp.db
*.sqlite3

# ── Node / 前端 ──────────────────────────────────────────────────────────────
node_modules/
dist/
build/
.next/
out/
.nuxt/
.turbo/
.vite/
coverage/
.npm/
.yarn/
.pnpm-store/
*.tsbuildinfo

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── 環境變數 / 機密 ──────────────────────────────────────────────────────────
# 只忽略實際的 .env，不要忽略範本
.env
.env.local
.env.*.local
*.pem
*.key

# ── IDE / 編輯器 ─────────────────────────────────────────────────────────────
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*~

# ── OS 產物 ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Claude Code 本地設定（user-local，不該共享）───────────────────────────────
.claude/settings.local.json

# ── Logs / 暫存 ──────────────────────────────────────────────────────────────
*.log
logs/
tmp/
temp/

# ── runtime_logic（reference codebases — only README.md tracked）─────────────
# Sprint 9 X update: structure changed from a single TS reference at
# ``runtime_logic/src/`` to per-codebase subdirs. Both ``claude-code-src``
# (TypeScript Claude Code internals) and ``openai-agents-python`` (OpenAI
# Agents SDK) are studied locally for AgenticRAG enhancement work but
# their source trees stay out of this repo. Add a new subdir-style entry
# whenever a fresh reference codebase lands here.
runtime_logic/claude-code-src/
runtime_logic/openai-agents-python/
# Legacy single-tree paths kept for back-compat with branches still on
# the old layout — harmless to leave.
runtime_logic/src/
runtime_logic/vendor/
runtime_logic/node_modules/

# ── runtime data: n8n workflow assets / uploads ───────────────────────────────
# Static templates (e.g. fina./) and user uploads served by nginx at /static
# and /uploads. These are workflow-specific runtime data, not source code —
# back them up out-of-band. README.md is tracked so the directory layout
# stays self-documenting for fresh checkouts.
share/static/
share/uploads/
# code-server 的工作目錄（C3 收斂後，預設不再掛 repo root）。
# 由 ops 自行決定要塞什麼進這個 sandbox；不 commit 內容。
share/codeserver-sandbox/

# ── Misc dev tooling ──────────────────────────────────────────────────────────
# Observer / loop process locks
.observer.lock
*.observer.lock


# Onyx upstream clone — handed off to the agent dev team for ongoing
# maintenance. Their code, their repo. Kept on disk for local reference
# but not under our version control. The handover spec we owe them
# stays tracked at docs/onyx-target-system-api-spec.md and
# docs/onyx-application-plan.md.
onyx/
